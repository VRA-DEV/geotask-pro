# =============================================================================
# GeoTask Pro — Environment Variables
# =============================================================================
# Copie este arquivo para .env.local e preencha com seus valores:
#   cp .env.example .env.local
#
# NUNCA commite .env ou .env.local no repositorio.
# =============================================================================

# --- Banco de Dados (obrigatorio) -------------------------------------------
# Connection string do PostgreSQL.
# Para desenvolvimento local com Docker Compose: postgresql://postgres:SUA_SENHA@127.0.0.1:5433/geotask-pro-v2
# Para producao (Neon/Supabase/RDS): use a connection string fornecida pelo provedor
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# --- Seguranca (obrigatorio) ------------------------------------------------
# Chave secreta para JWT. Gere com: openssl rand -base64 32
JWT_SECRET=""

# Chave secreta para endpoints cron. Gere com: openssl rand -base64 32
CRON_SECRET=""

# Senha padrao para novos usuarios (eles devem alterar no primeiro acesso)
DEFAULT_USER_PASSWORD="Mudar@123"

# --- Storage / Supabase (opcional) ------------------------------------------
# Necessario apenas se usar Supabase Storage para uploads em cloud.
# Se nao configurado, uploads sao armazenados no file system local.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# --- IA / Relatorios (opcional) ---------------------------------------------
# API key do XAI (Grok) para geracao de relatorios com IA.
# Se nao configurado, a funcionalidade de relatorios IA fica desativada.
XAI_API_KEY=""
