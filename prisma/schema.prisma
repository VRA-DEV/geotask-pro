generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   Int            @id @default(autoincrement())
  name                 String
  email                String         @unique
  password_hash        String         @default("mock")
  role_id              Int
  sector_id            Int
  avatar               String?
  active               Boolean        @default(true)
  must_change_password Boolean        @default(true)
  created_at           DateTime       @default(now())
  comments             Comment[]
  mentions_created     Mention[]      @relation("MentionedBy")
  mentions_received    Mention[]      @relation("MentionedUser")
  notifications        Notification[]
  subtasks             Subtask[]
  tasks_created        Task[]         @relation("CreatedBy")
  tasks_responsible    Task[]         @relation("Responsible")
  task_history         TaskHistory[]
  templates            Template[]
  template_subtasks    TemplateSubtask[]
  Role                 Role           @relation(fields: [role_id], references: [id])
  Sector               Sector         @relation(fields: [sector_id], references: [id])
}

model Task {
  id              Int            @id @default(autoincrement())
  title           String
  description     String?
  type            String?
  status          String         @default("A Fazer")
  priority        String?
  sector_id       Int?
  responsible_id  Int?
  contract_id     Int?
  city_id         Int?
  neighborhood_id Int?
  nucleus         String?
  quadra          String?
  lote            String?
  deadline        DateTime?
  link            String?
  created_by_id   Int?
  created_at      DateTime       @default(now())
  updated_at      DateTime?      @updatedAt
  started_at      DateTime?
  paused_at       DateTime?
  completed_at    DateTime?
  time_spent      Int            @default(0)
  parent_id       Int?
  comments        Comment[]
  mentions        Mention[]
  notifications   Notification[]
  subtasks        Subtask[]
  city            City?          @relation(fields: [city_id], references: [id])
  contract        Contract?      @relation(fields: [contract_id], references: [id])
  created_by      User?          @relation("CreatedBy", fields: [created_by_id], references: [id])
  neighborhood    Neighborhood?  @relation(fields: [neighborhood_id], references: [id])
  parent          Task?          @relation("TaskSubtasks", fields: [parent_id], references: [id])
  children        Task[]         @relation("TaskSubtasks")
  responsible     User?          @relation("Responsible", fields: [responsible_id], references: [id])
  Sector          Sector?        @relation(fields: [sector_id], references: [id])
  history         TaskHistory[]
  pauses          TaskPause[]

  @@index([responsible_id])
  @@index([sector_id])
  @@index([status])
  @@index([parent_id])
  @@index([created_by_id])
}

model Subtask {
  id             Int       @id @default(autoincrement())
  title          String
  done           Boolean   @default(false)
  sector_id      Int?
  task_id        Int
  responsible_id Int?
  done_at        DateTime?
  responsible    User?     @relation(fields: [responsible_id], references: [id])
  Sector         Sector?   @relation(fields: [sector_id], references: [id])
  task           Task      @relation(fields: [task_id], references: [id], onDelete: Cascade)
}

model Template {
  id            Int            @id @default(autoincrement())
  name          String
  sector_id     Int
  created_by_id Int?
  created_at    DateTime       @default(now())
  created_by    User?          @relation(fields: [created_by_id], references: [id])
  Sector        Sector         @relation(fields: [sector_id], references: [id])
  tasks         TemplateTask[]
}

model TemplateTask {
  id          Int               @id @default(autoincrement())
  title       String
  order_index Int               @default(0)
  template_id Int
  subtasks    TemplateSubtask[]
  template    Template          @relation(fields: [template_id], references: [id], onDelete: Cascade)
}

model TemplateSubtask {
  id               Int          @id @default(autoincrement())
  title            String
  order_index      Int          @default(0)
  template_task_id Int
  sector_id        Int?
  responsible_id   Int?
  template_task    TemplateTask @relation(fields: [template_task_id], references: [id], onDelete: Cascade)
  Sector           Sector?      @relation(fields: [sector_id], references: [id])
  responsible      User?        @relation(fields: [responsible_id], references: [id])
}

model Comment {
  id            Int            @id @default(autoincrement())
  content       String
  created_at    DateTime       @default(now())
  task_id       Int
  user_id       Int?
  task          Task           @relation(fields: [task_id], references: [id], onDelete: Cascade)
  user          User?          @relation(fields: [user_id], references: [id])
  mentions      Mention[]
  notifications Notification[]

  @@index([task_id])
}

model TaskPause {
  id         Int       @id @default(autoincrement())
  task_id    Int
  started_at DateTime  @default(now())
  ended_at   DateTime?
  task       Task      @relation(fields: [task_id], references: [id], onDelete: Cascade)
}

model Mention {
  id                  Int      @id @default(autoincrement())
  mention_type        String
  mentioned_sector_id Int?
  created_at          DateTime @default(now())
  comment_id          Int
  task_id             Int
  mentioned_user_id   Int?
  mentioned_by_id     Int?
  comment             Comment  @relation(fields: [comment_id], references: [id], onDelete: Cascade)
  mentioned_by        User?    @relation("MentionedBy", fields: [mentioned_by_id], references: [id])
  Sector              Sector?  @relation(fields: [mentioned_sector_id], references: [id])
  mentioned_user      User?    @relation("MentionedUser", fields: [mentioned_user_id], references: [id])
  task                Task     @relation(fields: [task_id], references: [id], onDelete: Cascade)
}

model Notification {
  id         Int      @id @default(autoincrement())
  type       String
  title      String
  message    String?
  read       Boolean  @default(false)
  created_at DateTime @default(now())
  user_id    Int
  task_id    Int?
  comment_id Int?
  comment    Comment? @relation(fields: [comment_id], references: [id])
  task       Task?    @relation(fields: [task_id], references: [id])
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, read])
  @@index([task_id])
}

model Contract {
  id    Int    @id @default(autoincrement())
  name  String @unique
  tasks Task[]
}

model City {
  id            Int            @id @default(autoincrement())
  name          String         @unique
  neighborhoods Neighborhood[]
  tasks         Task[]
}

model Neighborhood {
  id      Int    @id @default(autoincrement())
  name    String
  city_id Int
  city    City   @relation(fields: [city_id], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@unique([city_id, name])
}

model TaskHistory {
  id         Int      @id @default(autoincrement())
  task_id    Int
  user_id    Int?
  field      String
  old_value  String?
  new_value  String?
  created_at DateTime @default(now())
  task       Task     @relation(fields: [task_id], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [user_id], references: [id])

  @@index([task_id])
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  permissions Json?
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now()) @updatedAt
  User        User[]
}

model Sector {
  id         Int        @id @default(autoincrement())
  name       String     @unique
  created_at DateTime   @default(now())
  updated_at DateTime   @default(now()) @updatedAt
  Mention    Mention[]
  Subtask           Subtask[]
  Task              Task[]
  template_subtasks TemplateSubtask[]
  Template          Template[]
  User       User[]
  TaskType   TaskType[]
}

model TaskType {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  sector_id  Int?
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt
  Sector     Sector?  @relation(fields: [sector_id], references: [id], onDelete: SetNull)

  @@index([sector_id])
}
